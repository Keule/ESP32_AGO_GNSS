{
  "build": {
    "arduino": {
      "ldscript": "esp32_out.ld",
      "partitions": "default_16MB.csv"
    },
    "core": "esp32",
    "extra_flags": [
      "-DARDUINO_LILYGO_T_ETH_LITE",
      "-DARDUINO_RUNNING_CORE=1",
      "-DARDUINO_EVENT_RUNNING_CORE=1",
      "-DBOARD_HAS_PSRAM",
      "-DCONFIG_SPIRAM_IGNORE_NOTFOUND=1"
    ],
    "f_cpu": "240000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "mcu": "esp32",
    "variant": "esp32"
  },
  "connectivity": [
    "wifi"
  ],
  "debug": {
    "default_tool": "esp-builtin",
    "onboard_tools": ["esp-builtin"],
    "openocd_target": "esp32.cfg"
  },
  "frameworks": ["arduino", "espidf"],
  "name": "LilyGO T-ETH-Lite (ESP32, 16MB Flash, PSRAM)",
  "upload": {
    "flash_size": "16MB",
    "maximum_ram_size": 327680,
    "maximum_size": 16777216,
    "require_upload_port": true,
    "speed": 921600
  },
  "url": "https://www.lilygo.cc/products/t-eth-lite",
  "vendor": "LilyGO"
}
